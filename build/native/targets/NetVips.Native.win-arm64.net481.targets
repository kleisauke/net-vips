<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

    <PropertyGroup>
        <LibvipsOutputBase Condition="'$(LibvipsOutputBase)' == ''"></LibvipsOutputBase>
        <LibvipsOutputBase Condition="'$(LibvipsOutputBase)' != ''">$([MSBuild]::EnsureTrailingSlash('$(LibvipsOutputBase)'))</LibvipsOutputBase>
    </PropertyGroup>

    <!-- This copy step is only necessary when our platform is ARM64 -->
    <ItemGroup Condition="'$(Platform)' == 'ARM64' OR '$(Platform)|$(PreferNativeArm64)' == 'AnyCPU|true'">
        <None Include="$(MSBuildThisFileDirectory)..\..\runtimes\win-arm64\native\*">
            <Link>$(LibvipsOutputBase)%(Filename)%(Extension)</Link>
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </None>
    </ItemGroup>

</Project>